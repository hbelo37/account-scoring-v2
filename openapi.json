{
  "openapi": "3.1.0",
  "info": {
    "title": "Account Scoring Skill",
    "version": "1.0.0",
    "description": "Score companies against an ICP derived from existing customers."
  },
  "servers": [
    {
      "url": "https://account-scoring-v2.onrender.com"
    }
  ],
  "paths": {
    "/set-icp": {
      "post": {
        "operationId": "setICP",
        "summary": "Set ICP from customer list",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "customers": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["customers"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ICP stored"
          }
        }
      }
    },
    "/score": {
      "post": {
        "operationId": "scoreCompanies",
        "summary": "Score companies against stored ICP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "companies": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["companies"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Scoring results"
          }
        }
      }
    }
  }
}
